<Window x:Class="MusicDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MusicDownloader.ViewModels"
        mc:Ignorable="d"
        Title="🎵 音乐下载器 v2.8.16"
        Height="760" Width="1100"
        MinHeight="640" MinWidth="900"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing">

    <Window.Resources>
        <vm:FileToolViewModel x:Key="FileTool"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🎵 音乐下载器" FontSize="22" FontWeight="Bold" Foreground="#E4E4F0"/>
            <TextBlock Text="网易云 · 酷我 · 酷狗 · 咪咕 多源搜索，自动过滤非原唱，支持 flac 无损"
                       FontSize="12" Foreground="#9090A0" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 搜索栏 -->
        <Border Grid.Row="1" Background="#2A2A3C" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 搜索框 -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown"/>
                    <TextBlock Text="输入歌名或歌手..." IsHitTestVisible="False"
                               Foreground="#606070" VerticalAlignment="Center" Margin="12,0"
                               Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource EmptyToVisibleConverter}, FallbackValue=Collapsed}"/>
                </Grid>

                <Button Grid.Row="0" Grid.Column="1" Content="🔍 搜索"
                        Command="{Binding SearchCommand}"
                        IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ModernButton}"
                        Margin="0,0,0,12" MinWidth="100"/>

                <!-- 选项行 -->
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="2">
                    <TextBlock Text="来源:" VerticalAlignment="Center" Foreground="#9090A0" Margin="0,0,12,0" FontSize="12"/>
                    <CheckBox Content="网易云" IsChecked="{Binding SourceNetease}" Margin="0,0,12,0"/>
                    <CheckBox Content="酷我" IsChecked="{Binding SourceKuwo}" Margin="0,0,12,0"/>
                    <CheckBox Content="酷狗" IsChecked="{Binding SourceKugou}" Margin="0,0,12,0"/>
                    <CheckBox Content="咪咕" IsChecked="{Binding SourceMigge}" Margin="0,0,24,0" Foreground="#E74C3C"/>

                    <TextBlock Text="过滤:" VerticalAlignment="Center" Foreground="#9090A0" Margin="0,0,12,0" FontSize="12"/>
                    <CheckBox Content="Cover" IsChecked="{Binding FilterCover}" Margin="0,0,12,0" Foreground="#2980B9"/>
                    <CheckBox Content="DJ版" IsChecked="{Binding FilterDj}" Margin="0,0,12,0" Foreground="#E74C3C"/>
                    <CheckBox Content="AI版" IsChecked="{Binding FilterAi}" Margin="0,0,24,0" Foreground="#8E44AD"/>

                    <TextBlock Text="数量:" VerticalAlignment="Center" Foreground="#9090A0" Margin="0,0,8,0" FontSize="12"/>
                    <Slider x:Name="LimitSlider" Width="80" Minimum="10" Maximum="1000"
                            Value="{Binding SearchLimit}" VerticalAlignment="Center"
                            IsSnapToTickEnabled="False"/>
                    <TextBox Text="{Binding SearchLimit, UpdateSourceTrigger=PropertyChanged}"
                             Width="50" FontSize="12" VerticalAlignment="Center"
                             HorizontalContentAlignment="Center" Padding="4,2"
                             ToolTip="直接输入数量"/>
                    <TextBlock Text="首" VerticalAlignment="Center" Foreground="#9090A0" Margin="4,0,16,0" FontSize="12"/>

                    <TextBlock Text="下载至:" VerticalAlignment="Center" Foreground="#9090A0" Margin="0,0,8,0" FontSize="12"/>
                    <TextBox Text="{Binding DownloadPath}" Width="160" FontSize="12" Padding="8,6" Margin="0,0,6,0"
                             VerticalContentAlignment="Center"/>
                    <Button Content="📂"
                            Command="{Binding BrowseDownloadPathCommand}"
                            ToolTip="浏览选择下载目录"
                            Padding="6,6" FontSize="11" Margin="0,0,12,0"
                            Cursor="Hand" Background="#404060" Foreground="#E4E4F0" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505070"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="格式:" VerticalAlignment="Center" Foreground="#9090A0" Margin="0,0,8,0" FontSize="12"/>
                    <CheckBox Content="FLAC" IsChecked="{Binding FormatFlac}" Margin="0,0,8,0" Foreground="#E74C3C" FontSize="12" ToolTip="无损格式，品质最好"/>
                    <CheckBox Content="MP3" IsChecked="{Binding FormatMp3}" Margin="0,0,8,0" Foreground="#2980B9" FontSize="12" ToolTip="高品有损，兼容性最好"/>
                    <CheckBox Content="AAC" IsChecked="{Binding FormatAac}" Margin="0,0,8,0" Foreground="#27AE60" FontSize="12" ToolTip="高品有损，iTunes常用"/>
                    <CheckBox Content="WAV" IsChecked="{Binding FormatWav}" Margin="0,0,12,0" Foreground="#8E44AD" FontSize="12" ToolTip="无损PCM，体积最大"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="160"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 搜索结果 -->
            <Border Grid.Column="0" Background="#2A2A3C" CornerRadius="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#33334D" CornerRadius="8,8,0,0" Padding="14,10">
                        <Grid>
                            <TextBlock Text="{Binding SearchResults.Count, StringFormat='搜索结果 ({0} 首)'}"
                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="全选" Command="{Binding SelectAllCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                                <Button Content="取消" Command="{Binding SelectNoneCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                                <Button Content="加入下载 ⬇" Command="{Binding AddToQueueCommand}"
                                        Style="{StaticResource ModernButton}" Padding="10,4" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 列表 -->
                    <ListBox Grid.Row="1" x:Name="ResultsList"
                             ItemsSource="{Binding SearchResults}"
                             SelectionMode="Extended"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             SelectionChanged="ResultsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="55"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="11" Foreground="#9090A0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationStr}" FontSize="11"
                                               Foreground="#9090A0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Border Grid.Column="3" Background="{Binding Format, Converter={StaticResource FormatToBgConverter}}"
                                            CornerRadius="4" Padding="5,2"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            ToolTip="音频格式">
                                        <TextBlock Text="{Binding Format, Converter={StaticResource FormatTextConverter}}"
                                                   FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <Border Grid.Column="4" Background="#404060" CornerRadius="4" Padding="5,2"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#A0A0B0"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E4E4F0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#404060"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#353548"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- 加载中 -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="正在搜索..." FontSize="14" Foreground="#9090A0" HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- 空状态 -->
                    <TextBlock Grid.Row="1" Text="输入关键词开始搜索 🎵"
                               FontSize="14" Foreground="#606070"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SearchResults.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                </Grid>
            </Border>

            <!-- 分隔条1 -->
            <GridSplitter Grid.Column="1" Width="6" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Cursor="SizeWE" ShowsPreview="True"/>

            <!-- 下载队列 -->
            <Border Grid.Column="2" Background="#2A2A3C" CornerRadius="8" Margin="4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#33334D" CornerRadius="8,8,0,0" Padding="14,10">
                        <Grid>
                            <TextBlock Text="{Binding DownloadQueue.Count, StringFormat='下载队列 ({0} 首)'}"
                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                            <Button Content="清空" Command="{Binding ClearQueueCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="8,3"
                                    FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" x:Name="QueueList"
                             ItemsSource="{Binding DownloadQueue}"
                             SelectionMode="Single"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             SelectionChanged="SyncSelection">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- 歌名 -->
                                    <TextBlock Grid.Row="0" FontSize="12" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Song.Artist, Mode=OneWay}" Foreground="#E4E4F0"/>
                                        <Run Text=" - " Foreground="#606070"/>
                                        <Run Text="{Binding Song.Title, Mode=OneWay}" Foreground="#E4E4F0"/>
                                    </TextBlock>
                                    <!-- 完整文件名预览 -->
                                    <TextBlock Grid.Row="1" FontSize="10" Foreground="#7C3AED" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding FinalFileName, Mode=OneWay}"/>
                                        <Run Text="." Foreground="#606070"/>
                                        <Run Text="{Binding Song.Format, Mode=OneWay}" Foreground="#E74C3C"/>
                                    </TextBlock>
                                    <!-- 进度条 + 状态 -->
                                    <Grid Grid.Row="2" Margin="0,3,0,0">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="3"
                                                     Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                        <TextBlock Text="{Binding Status}" FontSize="10" Margin="0,4,0,0"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToTextColorConverter}}"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2" Content="▶ 开始下载"
                            Command="{Binding StartDownloadCommand}"
                            Style="{StaticResource ModernButton}"
                            Margin="12" HorizontalAlignment="Stretch"
                            Visibility="{Binding IsDownloading, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Grid.Row="2" Content="⏹ 取消下载"
                            Command="{Binding CancelDownloadCommand}"
                            Style="{StaticResource ModernButton}"
                            Background="#E74C3C"
                            Margin="12" HorizontalAlignment="Stretch"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- 分隔条2 -->
            <GridSplitter Grid.Column="3" Width="6" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Cursor="SizeWE" ShowsPreview="True"/>

            <!-- 文件名编辑 -->
            <Border Grid.Column="4" Background="#2A2A3C" CornerRadius="8" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#33334D" CornerRadius="8,8,0,0" Padding="12,10">
                        <TextBlock Text="📝 文件名编辑" Style="{StaticResource SectionTitle}" Margin="0"/>
                    </Border>

                    <ListBox Grid.Row="1" x:Name="FilenameList"
                             ItemsSource="{Binding DownloadQueue}"
                             SelectionMode="Single"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             SelectionChanged="SyncSelection">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- 歌名 -->
                                    <TextBlock Grid.Row="0" FontSize="11" TextTrimming="CharacterEllipsis"
                                               Foreground="#9090A0" Margin="0,0,0,2">
                                        <Run Text="{Binding Song.Artist, Mode=OneWay}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding Song.Title, Mode=OneWay}"/>
                                    </TextBlock>
                                    <!-- 文件名输入框 -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding FinalFileName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Foreground="#E4E4F0" Background="#353548"
                                                 BorderThickness="1" BorderBrush="#404060"
                                                 Padding="6,4" VerticalAlignment="Center"
                                                 ToolTip="编辑文件名（不含扩展名）"/>
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#E74C3C" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <Run Text="."/><Run Text="{Binding Song.Format, Mode=OneWay}" FontWeight="Bold"/>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 空状态 -->
                    <TextBlock Grid.Row="1" Text="加入歌曲后可编辑文件名"
                               FontSize="12" Foreground="#606070"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding DownloadQueue.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="#2A2A3C" CornerRadius="6" Margin="0,8,0,0" Padding="12,8">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#9090A0"/>
                <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="#505060">
                    <Run Text="已选 "/><Run Text="{Binding SelectedSongs.Count, Mode=OneWay}"/><Run Text=" 首"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- 主内容区与文件工具之间的可调节分隔 -->
        <GridSplitter Grid.Row="4" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Background="Transparent"
                      Cursor="SizeNS" ShowsPreview="True"/>

        <!-- 文件工具区 -->
        <Border Grid.Row="5" Background="#2A2A3C" CornerRadius="8" Margin="0,0,0,0"
                DataContext="{StaticResource FileTool}">
            <Expander IsExpanded="True" Background="Transparent" BorderThickness="0" Foreground="#E4E4F0">
                <Expander.Header>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E4E4F0"
                               Margin="4,0">🔧 文件工具 — 核对、清洗重命名、删除非原唱</TextBlock>
                </Expander.Header>
                <Grid Margin="12,8,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 路径行 -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="目标路径:" VerticalAlignment="Center"
                                   Foreground="#9090A0" FontSize="12" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Padding="8,6" Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="输入目标文件路径或文件夹路径"/>
                        <Button Grid.Column="2" Content="📂 浏览"
                                Command="{Binding BrowsePathCommand}"
                                Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                Cursor="Hand" Background="#404060" Foreground="#E4E4F0"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#505070"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <CheckBox Grid.Column="3" Content="包含子文件夹" IsChecked="{Binding Recursive}"
                                  VerticalAlignment="Center" FontSize="12" Foreground="#9090A0"/>
                    </Grid>

                    <!-- 操作按钮行 -->
                    <StackPanel Grid.Row="1" Orientation="Vertical">
                        <!-- 删除类型勾选 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="删除类型:" VerticalAlignment="Center"
                                       Foreground="#9090A0" FontSize="12" Margin="0,0,10,0"/>
                            <CheckBox Content="Cover 翻唱" IsChecked="{Binding DeleteCover}"
                                      VerticalAlignment="Center" FontSize="12" Foreground="#2980B9" Margin="0,0,16,0"/>
                            <CheckBox Content="DJ 版" IsChecked="{Binding DeleteDj}"
                                      VerticalAlignment="Center" FontSize="12" Foreground="#E74C3C" Margin="0,0,16,0"/>
                            <CheckBox Content="AI 版" IsChecked="{Binding DeleteAi}"
                                      VerticalAlignment="Center" FontSize="12" Foreground="#8E44AD" Margin="0,0,0,0"/>
                        </StackPanel>
                        <!-- 按钮行 -->
                        <StackPanel Orientation="Horizontal">
                        <Button Content="🔍 核对与重命名"
                                Command="{Binding ScanAndRenameCommand}"
                                IsEnabled="{Binding IsWorking, Converter={StaticResource InverseBoolConverter}}"
                                Padding="14,7" FontSize="12" Margin="0,0,10,0" Cursor="Hand"
                                Background="#7C3AED" Foreground="White" BorderThickness="0"
                                ToolTip="扫描文件 → 网易云可信源验证 → 清洗重命名">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#6D28D9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="⏸ 暂停"
                                Command="{Binding PauseOperationCommand}"
                                Padding="10,7" FontSize="12" Margin="0,0,10,0" Cursor="Hand"
                                Background="#F59E0B" Foreground="White" BorderThickness="0"
                                Visibility="{Binding CanPause, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="暂停当前操作（核对或重命名过程中均可暂停）">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D97706"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="🗑️ 删除 Cover/DJ/AI"
                                Command="{Binding DeleteTypeFilesCommand}"
                                IsEnabled="{Binding IsWorking, Converter={StaticResource InverseBoolConverter}}"
                                Padding="14,7" FontSize="12" Margin="0,0,10,0" Cursor="Hand"
                                Background="#E74C3C" Foreground="White" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C0392B"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Text="{Binding ToolStatusText}" VerticalAlignment="Center"
                                   FontSize="12" Foreground="#9090A0" Margin="8,0,0,0"/>
                        <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="8,0,0,0"
                                     Visibility="{Binding IsWorking, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Expander>
        </Border>
    </Grid>
