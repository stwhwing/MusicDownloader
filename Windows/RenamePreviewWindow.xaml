<Window x:Class="MusicDownloader.Windows.RenamePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名预览 — 可编辑后确认执行"
        Height="640" Width="900"
        MinHeight="400" MinWidth="700"
        Background="#1E1E2E"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E4E4F0"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>
        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background" Value="#33334D"/>
            <Setter Property="Foreground" Value="#E4E4F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#404060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Text="📝 重命名预览"/>
            <TextBlock x:Name="SubTitleText" FontSize="12" Foreground="#9090A0" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 统计摘要 -->
        <Border Grid.Row="1" Background="#2A2A3C" CornerRadius="8" Padding="16,10" Margin="0,0,0,10">
            <StackPanel x:Name="SummaryPanel" Orientation="Horizontal"/>
        </Border>

        <!-- 可编辑列表 -->
        <Border Grid.Row="2" Background="#2A2A3C" CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 表头 -->
                <Border Grid.Row="0" Background="#33334D" CornerRadius="8,8,0,0" Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="11" Foreground="#9090A0"/>
                        <TextBlock Grid.Column="1" Text="原文件名" FontSize="11" Foreground="#9090A0"/>
                        <TextBlock Grid.Column="2" Text="→" FontSize="11" Foreground="#606070" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="网易云匹配（可信源）" FontSize="11" Foreground="#2980B9"/>
                        <TextBlock Grid.Column="4" Text="拟修改文件名" FontSize="11" Foreground="#9090A0"/>
                        <TextBlock Grid.Column="5" Text="状态" FontSize="11" Foreground="#9090A0" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RenameList" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#33334D" BorderThickness="0,0,0,1">
                                    <Grid Margin="10,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 序号 -->
                                        <TextBlock Grid.Column="0" Text="{Binding Index}"
                                                   FontSize="11" Foreground="#606070" VerticalAlignment="Center"/>
                                        <!-- 原文件名 -->
                                        <TextBlock Grid.Column="1" Text="{Binding OriginalFileName}"
                                                   FontSize="12" Foreground="#9090A0" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding OriginalFileName}"/>
                                        <!-- 箭头 -->
                                        <TextBlock Grid.Column="2" Text="→" FontSize="12"
                                                   Foreground="#606070" VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                        <!-- 网易云可信源匹配 -->
                                        <TextBlock Grid.Column="3" Text="{Binding VerifiedMatch}"
                                                   FontSize="11" Foreground="#2980B9" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding VerifiedMatch}"
                                                   FontStyle="Italic"/>
                                        <!-- 拟修改文件名（可编辑 TextBox） -->
                                        <TextBox Grid.Column="4"
                                                 Text="{Binding NewFileName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Foreground="#E4E4F0" Background="#353548"
                                                 BorderThickness="1" BorderBrush="#404060"
                                                 Padding="6,3" VerticalAlignment="Center"
                                                 ToolTip="直接在此编辑拟修改文件名（不含扩展名）"
                                                 IsEnabled="{Binding IsEditable}"/>
                                        <!-- 状态 -->
                                        <TextBlock Grid.Column="5" Text="{Binding StatusLabel}"
                                                   FontSize="11" Foreground="{Binding StatusColor}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   ToolTip="{Binding VerifyNote}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 按钮 -->
        <Grid Grid.Row="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock x:Name="HintText" VerticalAlignment="Center"
                           FontSize="12" Foreground="#9090A0"
                           Text="提示：直接修改「新文件名」列可自定义目标名"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ConfirmBtn" Content="✅ 确认执行重命名"
                        Style="{StaticResource GreenBtn}" Margin="0,0,8,0"
                        Click="ConfirmBtn_Click"/>
                <Button Content="取消" Style="{StaticResource SecBtn}" Click="CancelBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
