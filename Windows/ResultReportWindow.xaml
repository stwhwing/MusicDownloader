<Window x:Class="MusicDownloader.Windows.ResultReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作结果报告"
        Height="600" Width="820"
        MinHeight="400" MinWidth="600"
        Background="#1E1E2E"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E4E4F0"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Background" Value="#33334D"/>
            <Setter Property="Foreground" Value="#E4E4F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#404060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="#E4E4F0"/>
            <TextBlock x:Name="SubTitleText" FontSize="12" Foreground="#9090A0" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 统计摘要 -->
        <Border Grid.Row="1" Background="#2A2A3C" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <StackPanel x:Name="SummaryPanel" Orientation="Horizontal" HorizontalAlignment="Left"/>
        </Border>

        <!-- 详细列表 -->
        <Border Grid.Row="2" Background="#2A2A3C" CornerRadius="8" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 表头 -->
                <Border Grid.Row="0" Background="#33334D" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="11" Foreground="#9090A0"/>
                        <TextBlock Grid.Column="1" Text="文件名 / 变更" FontSize="11" Foreground="#9090A0"/>
                        <TextBlock Grid.Column="2" Text="结果/备注" FontSize="11" Foreground="#9090A0"/>
                    </Grid>
                </Border>
                <!-- 使用 ItemsControl 避免 GridView 的复杂性 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ResultList" Background="Transparent">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#33334D" BorderThickness="0,0,0,1">
                                    <Grid Margin="12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}"
                                                   FontSize="11" Foreground="#606070" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="12"
                                                       Foreground="#E4E4F0" TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FileName}"/>
                                            <TextBlock Text="{Binding SubText}" FontSize="10"
                                                       Foreground="#9090A0" Margin="0,2,0,0"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding SubText}"
                                                       Visibility="{Binding HasSubText, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Note}"
                                                   FontSize="11" VerticalAlignment="Top"
                                                   Foreground="{Binding NoteColor}"
                                                   TextWrapping="Wrap"
                                                   ToolTip="{Binding Note}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 按钮 -->
        <StackPanel x:Name="ButtonPanel" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="📋 复制到剪贴板" Style="{StaticResource SecBtn}"
                    Click="CopyToClipboard" Margin="0,0,8,0"/>
            <Button Content="关闭" Style="{StaticResource ActionBtn}" Click="CloseWindow"/>
        </StackPanel>
    </Grid>
</Window>
